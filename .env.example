# -------------------------------------------------------------------------
# trading-chatbot environment variables template
# Copy this file to .env and fill in the real values.
# DO NOT commit .env — it is gitignored.
#
# Vars marked (required) have NO default in docker-compose.production.yml —
# if left empty, compose substitutes an empty string and services fail to
# start (e.g. Postgres refuses to init without POSTGRES_PASSWORD).
# -------------------------------------------------------------------------

# --- Postgres (required for production compose) --------------------------
# Superuser/app password. Also interpolated into the backend DATABASE_URL.
# Generate one: openssl rand -base64 24 | tr -d '/+=' | head -c 32
POSTGRES_PASSWORD=

# --- Auth (required) -----------------------------------------------------
# Secret for signing JWTs. Generate: openssl rand -hex 32
JWT_SECRET=

# --- Pinecone — read-only access to the trade-reports index --------------
# "Reader" role key from https://app.pinecone.io -> Project -> API keys
PINECONE_READ_KEY=
PINECONE_HOST=
PINECONE_INDEX=trade-reports
PINECONE_NAMESPACE=trade

# --- OpenAI — used by the RAG chat endpoint ------------------------------
OPENAI_API_KEY=

# --- Magic-link email ----------------------------------------------------
EMAIL_PROVIDER_API_KEY=
MAGIC_LINK_FROM_EMAIL=Trading Chatbot <noreply@mga-pservices.cloud>

# --- URLs / CORS ---------------------------------------------------------
# NEXT_PUBLIC_API_BASE is baked into the client bundle at build time.
NEXT_PUBLIC_API_BASE=http://localhost:8000
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# --- Ports (optional — defaults shown) -----------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# -------------------------------------------------------------------------
# Local dev (docker-compose.yml) uses SQLite instead of Postgres:
#   DATABASE_URL=sqlite:///./chat.db
#
# Frontend dev server reads frontend/.env.local (gitignored):
#   NEXT_PUBLIC_API_BASE=http://localhost:8000
# -------------------------------------------------------------------------
