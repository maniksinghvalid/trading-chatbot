# -------------------------------------------------------------------------
# trading-chatbot environment variables template
# Copy this file to .env and fill in the real values.
# DO NOT commit .env — it is gitignored.
# -------------------------------------------------------------------------

# Pinecone — read-only access to the trade-reports index produced by ai-trading-claude.
# Generate a "Reader" role key at: https://app.pinecone.io -> Project -> API keys
PINECONE_READ_KEY=
PINECONE_INDEX=trade-reports
PINECONE_NAMESPACE=trade

# OpenAI — used by the RAG chat endpoint
OPENAI_API_KEY=

# Database — SQLite (Phase 1); switch to postgresql+psycopg://... for Phase 2 Postgres
DATABASE_URL=sqlite:///./chat.db

# CORS — comma-separated origins the backend should allow (frontend dev server)
CORS_ORIGINS=http://localhost:3000

# -------------------------------------------------------------------------
# Frontend note (slice 5 / plan 01-06):
# The Next.js frontend uses frontend/.env.local (gitignored) with:
#   NEXT_PUBLIC_API_BASE=http://localhost:8000
# That file is authored in slice 5 (01-06); flagged here so the backend URL
# is discoverable from this bootstrap plan.
# -------------------------------------------------------------------------
