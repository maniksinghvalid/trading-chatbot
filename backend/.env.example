# .env.example — environment variable template for trading-chatbot backend
#
# Copy this file to .env and fill in the values for local development.
# Never commit a .env file with real secrets.
#
# SQLModel.metadata.create_all() builds all tables (Session, Turn, UserBudget)
# on first boot against whichever DATABASE_URL is configured — no migration
# tool is required at this scale.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Default: SQLite (zero-config, single-user / local dev only)
DATABASE_URL=sqlite:///./chat.db

# Postgres (multi-user, production-grade — requires docker-compose or a hosted PG):
# Start Postgres locally:  docker compose up -d
# Then switch to:
# DATABASE_URL=postgresql+psycopg://chatbot:chatbot@localhost:5432/chatbot

# ---------------------------------------------------------------------------
# Pinecone (read-only consumer key — never write to trade-reports index in v1)
# ---------------------------------------------------------------------------

PINECONE_READ_KEY=
PINECONE_INDEX=trade-reports
PINECONE_NAMESPACE=trade

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Auth — magic-link + JWT (slice 8 / AUTH-01)
# ---------------------------------------------------------------------------

# HS256 signing secret for magic-link tokens and session JWTs.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Magic-link email provider (Resend API key)
EMAIL_PROVIDER_API_KEY=

# URLs (update for staging / production deployments)
MAGIC_LINK_BASE_URL=http://localhost:8000/auth/callback
FRONTEND_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# CORS (comma-separated list of allowed origins for the backend)
# ---------------------------------------------------------------------------

# CORS_ORIGINS=["http://localhost:3000"]
